{
	"mcpServers": {
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@0.0.38",
				"--isolated",
				"--browser",
				"chromium"
			],
			"alwaysAllow": [
				"browser_navigate",
				"browser_wait_for",
				"browser_type",
				"browser_click",
				"browser_close",
				"browser_resize",
				"browser_console_messages",
				"browser_handle_dialog",
				"browser_evaluate",
				"browser_file_upload",
				"browser_fill_form",
				"browser_install",
				"browser_press_key",
				"browser_navigate_back",
				"browser_network_requests",
				"browser_take_screenshot",
				"browser_snapshot",
				"browser_drag",
				"browser_hover",
				"browser_select_option",
				"browser_tabs"
			]
		}
	}
}